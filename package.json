{
  "name": "posh-dash",
  "version": "1.1.1",
  "description": "Sim racing telemetry overlay",
  "author": "sdcarter",
  "main": "dist/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite dev",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "build": "node scripts/fetch-car-data.mjs && tsc -p tsconfig.main.json && vite build",
    "fetch-car-data": "node scripts/fetch-car-data.mjs",
    "lint": "eslint src/ --max-warnings 0",
    "mock": "node scripts/run-mock-scenario.mjs default",
    "start": "npm run build && electron dist/main/index.js",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.poshdash.overlay",
    "productName": "PoshDash",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*"
    ],
    "icon": "assets/icon-256.png",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    },
    "publish": {
      "provider": "github",
      "owner": "sdcarter",
      "repo": "posh-overlay",
      "releaseType": "release"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@storybook/react": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "storybook": "^10.3.5",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.1"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "optionalDependencies": {
    "irsdk-node": "^4.4.0"
  }
}
